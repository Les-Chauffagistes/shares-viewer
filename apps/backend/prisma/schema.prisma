generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model RoundArchive {
  id           Int               @id @default(autoincrement())
  roundKey     String            @unique
  startedAt    DateTime?         @db.Timestamptz(3)
  endedAt      DateTime          @db.Timestamptz(3)
  workersCount Int
  sharesCount  Int
  bestShare    Float
  createdAt    DateTime          @default(now()) @db.Timestamptz(3)

  workerStats  WorkerRoundStat[]

  @@index([endedAt])
}

model WorkerRoundStat {
  id             Int           @id @default(autoincrement())
  roundArchiveId Int
  roundKey       String
  workerName     String
  worker         String
  addressId      String
  bestShare      Float
  sharesCount    Int
  rank           Int
  participated   Boolean
  streakAtTime   Int
  xpGained       Float
  totalXpAfter   Float
  levelAfter     Int
  createdAt      DateTime      @default(now()) @db.Timestamptz(3)

  roundArchive   RoundArchive  @relation(fields: [roundArchiveId], references: [id], onDelete: Cascade)
  address        WorkerAddress @relation(fields: [addressId], references: [id], onDelete: Restrict)

  @@index([roundKey])
  @@index([workerName])
  @@index([worker])
  @@index([addressId])
  @@index([rank])
  @@unique([roundKey, addressId, workerName])
}

model WorkerProfile {
  id                 Int           @id @default(autoincrement())
  workerName         String
  worker             String
  addressId          String
  bestShareEver      Float         @default(0)
  totalShares        Int           @default(0)
  roundsParticipated Int           @default(0)
  currentStreak      Int           @default(0)
  bestStreak         Int           @default(0)
  xp                 Float         @default(0)
  level              Int           @default(1)
  createdAt          DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime      @updatedAt @db.Timestamptz(3)

  address            WorkerAddress @relation(fields: [addressId], references: [id], onDelete: Restrict)

  @@unique([addressId, workerName])
  @@unique([addressId, worker])
  @@index([worker])
  @@index([level])
  @@index([bestShareEver])
  @@index([addressId])
}

model WorkerAddress {
  id               String   @id
  rawAddress       String   @unique
  isPublic         Boolean  @default(false)
  label            String
  createdAt        DateTime @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @db.Timestamptz(3)

  workerProfiles   WorkerProfile[]
  workerRoundStats WorkerRoundStat[]

  @@index([isPublic])
  @@index([label])
}